# Copy this file to .env and fill in values for your environment.
# Frontend variables must be prefixed with VITE_ to be exposed to the browser.

# URL of the Express backend (must match PORT below)
VITE_API_URL=http://localhost:3001

# Port the backend server listens on
PORT=3001

# Allowed CORS origin (your Vite dev server)
ALLOWED_ORIGIN=http://localhost:5173
